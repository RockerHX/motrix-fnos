{
  "name": "motrix-fnos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-dev.mjs",
    "tauri:build": "tauri build",
    "typecheck": "vue-tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "verify:pre-commit": "node scripts/verify.mjs --quick",
    "tauri:dev:raw": "tauri dev",
    "prepare": "git config core.hooksPath .githooks || true",
    "hooks:install": "git config core.hooksPath .githooks",
    "build:server:linux:x64": "node scripts/build-server-linux.mjs",
    "build:web:fpk": "node scripts/build-web-ui-fpk.mjs",
    "stage:aria2:x64": "node scripts/stage-aria2-sidecar.mjs --target x86_64-unknown-linux-gnu",
    "stage:aria2:arm64": "node scripts/stage-aria2-sidecar.mjs --target aarch64-unknown-linux-gnu"
  },
  "dependencies": {
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
